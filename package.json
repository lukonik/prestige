{
  "name": "root",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukonik/prestige.git"
  },
  "scripts": {
    "dev": "pnpm run --filter @lonik/prestige dev",
    "play": "pnpm run --filter @lonik/prestige play",
    "play:build": "pnpm run --filter @lonik/prestige play:build",
    "play:preview": "pnpm run --filter @lonik/prestige play:preview",
    "build": "pnpm run --filter @lonik/prestige build",
    "prestige:publish": "pnpm run --filter @lonik/prestige publish",
    "test": "pnpm run --filter @lonik/prestige test",
    "coverage": "pnpm run --filter @lonik/prestige test --coverage",
    "typecheck": "pnpm run --filter @lonik/prestige typecheck",
    "prepare": "husky",
    "build:all": "pnpm -p build",
    "test:all": "pnpm -p test",
    "release-v": "pnpm --filter prestige release-v",
    "docs": "pnpm run --filter docs dev",
    "install:template": "cd template && pnpm install --no-lockfile --ignore-workspace",
    "empty:release": "git commit --allow-empty -m \"fix: trigger release\"",
    "docs:build": "pnpm run --filter docs build"
  },
  "dependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "catalog:",
    "@semantic-release/git": "catalog:",
    "D": "^1.0.0",
    "semantic-release": "catalog:"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "packageManager": "pnpm@10.20.0",
  "version": "0.1.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
