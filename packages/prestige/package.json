{
  "name": "@lonik/prestige",
  "version": "0.0.3",
  "description": "Static Site Generator for Tanstack Start",
  "homepage": "https://github.com/lukonik/prestige#readme",
  "bugs": {
    "url": "https://github.com/lukonik/prestige/issues"
  },
  "license": "MIT",
  "author": "Luka Onikadze",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukonik/prestige.git"
  },
  "files": [
    "dist",
    "src/themes"
  ],
  "type": "module",
  "types": "./dist/client.d.ts",
  "exports": {
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    },
    "./themes/*": {
      "style": "./src/themes/*",
      "default": "./src/themes/*"
    },
    "./package.json": "./package.json",
    "./client": {
      "types": "./dist/client.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "play:build": "vite build",
    "play:preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && pnpm publish",
    "release-v": "bumpp minor --no-commit --no-tag --no-push --no-git-checks && pnpm publish --registry http://localhost:4873 --no-git-checks"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@docsearch/css": "^4.6.0",
    "@docsearch/react": "^4.6.0",
    "@lonik/themer": "^0.5.2",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/typography": "catalog:",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "hastscript": "9.0.1",
    "knitwork": "^1.3.0",
    "lucide-react": "catalog:",
    "pathe": "catalog:",
    "picomatch": "^4.0.3",
    "prism-react-renderer": "^2.4.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-flexible-toc": "^1.2.5",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-toc": "^9.0.0",
    "tinyglobby": "^0.2.15",
    "to-vfile": "^8.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "vfile-matter": "^5.0.1",
    "vite-tsconfig-paths": "catalog:",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-router": ">=1.0.0",
    "@tanstack/react-start": ">=1.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0 || ^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@lonik/oh-image": "^3.1.0",
    "@semantic-release/exec": "catalog:",
    "@semantic-release/git": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "catalog:",
    "@types/picomatch": "^4.0.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/unist": "^3.0.3",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.18",
    "bumpp": "catalog:",
    "memfs": "^4.56.10",
    "nitro": "catalog:",
    "publint": "^0.3.17",
    "react": "catalog:",
    "react-dom": "catalog:",
    "semantic-release": "catalog:",
    "sharp": "^0.34.5",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-inspect": "^11.3.3",
    "vitest": "catalog:",
    "vitest-browser-react": "^2.0.2"
  }
}
