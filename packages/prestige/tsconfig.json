{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "target": "esnext",
    "jsx": "react-jsx",
    "lib": ["es2023", "DOM"],
    "moduleDetection": "force",
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["./src/vite/client.d.ts", "vite/client"],
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "include": ["src", "playground"]
}
